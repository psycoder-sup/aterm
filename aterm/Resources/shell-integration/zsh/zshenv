# aterm ZDOTDIR bootstrap for zsh.
# Restores the user's real ZDOTDIR, sources their .zshenv,
# then loads aterm's zsh integration for interactive shells.

if [[ -n "${ATERM_ORIGINAL_ZDOTDIR+X}" ]]; then
    builtin export ZDOTDIR="$ATERM_ORIGINAL_ZDOTDIR"
    builtin unset ATERM_ORIGINAL_ZDOTDIR
else
    builtin unset ZDOTDIR
fi

{
    builtin typeset _aterm_file="${ZDOTDIR-$HOME}/.zshenv"
    [[ ! -r "$_aterm_file" ]] || builtin source -- "$_aterm_file"

    if [[ -o interactive \
       && -n "${ATERM_SHELL_INTEGRATION_DIR:-}" \
       && -r "${ATERM_SHELL_INTEGRATION_DIR}/aterm-zsh-integration.zsh" ]]; then
        builtin source -- "${ATERM_SHELL_INTEGRATION_DIR}/aterm-zsh-integration.zsh"
    fi
} always {
    builtin unset _aterm_file
}
