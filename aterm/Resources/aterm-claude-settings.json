{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.session_id' | xargs -I{} aterm-cli pane set-restore-command --command 'claude --resume {}' 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state active 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state needs_attention 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state busy 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state busy 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state idle 2>/dev/null || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state needs_attention 2>/dev/null || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state idle 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$ATERM_CLI_PATH status set --state inactive 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
